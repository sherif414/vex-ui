{
  "name": "@vex-ui/core",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/vex-ui.umd.cjs",
  "module": "./dist/vex-ui.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vex-ui.js",
      "require": "./dist/vex-ui.umd.cjs"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "types": "vue-tsc --declaration --emitDeclarationOnly",
    "preview": "vite preview",
    "publish": "pnpm publish --no-git-checks --access public",
    "test": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "up-dep": "taze major -I",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.0.2",
    "@heroicons/vue": "^2.0.18",
    "@unocss/reset": "^0.55.3",
    "@vueuse/core": "^10.3.0",
    "chartist": "^1.3.0",
    "focus-trap": "^7.5.2",
    "focus-trap-vue": "^4.0.2",
    "motion": "^10.16.2",
    "vue": "3.3.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^7.3.2",
    "@storybook/addon-essentials": "7.3.2",
    "@storybook/addon-interactions": "7.3.2",
    "@storybook/addon-links": "7.3.2",
    "@storybook/blocks": "7.3.2",
    "@storybook/testing-library": "0.2.0",
    "@storybook/vue3": "7.3.2",
    "@storybook/vue3-vite": "7.3.2",
    "@tsconfig/node18": "^18.2.1",
    "@types/jsdom": "^21.1.2",
    "@types/node": "^18.17.11",
    "@unocss/core": "^0.55.3",
    "@vitejs/plugin-vue": "^4.3.3",
    "@vitejs/plugin-vue-jsx": "^3.0.2",
    "@vue/test-utils": "^2.4.1",
    "@vue/tsconfig": "^0.4.0",
    "jsdom": "^22.1.0",
    "npm-run-all": "^4.1.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sass": "^1.66.1",
    "storybook": "7.3.2",
    "taze": "^0.11.2",
    "typescript": "^5.2.2",
    "unocss": "^0.55.3",
    "v-lazy-show": "^0.2.3",
    "vite": "^4.4.9",
    "vitest": "^0.34.3",
    "vue-tsc": "^1.8.8"
  }
}
